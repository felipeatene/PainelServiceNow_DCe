      "triggers": ["ativação", "emitir", "emissão", "gerar"],
      "scenarios": [
        "gerar uma DC-e para cada CNPJ",
        "gerar DC-e da GF com pedidos",
        "ativação VE leves",
        "ativação - emissão de DC-e Caminhões"
      ],
      "alert": "Validar autorização pré-autorização obrigatória",
      "color": "#0066cc"
    },
    "2": {
      "id": "2",
      "name": "CNPJ / PDI / Cadastro",
      "description": "Resolver problema de origem/identidade/cadastro",
      "triggers": ["cnpj", "pdi", "cd", "fornecedor", "rac", "gf", "42", "44"],
      "scenarios": [
        "gerar DC-e para cada CNPJ utilizado pelos PDI's",
        "gerar DC-e da GF com pedidos para 42 / 44"
      ],
      "alert": "Validar CNPJ em base de dados",
      "color": "#FF9800"
    },
