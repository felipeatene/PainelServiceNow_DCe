      "color": "#4CAF50"
    },
    "6": {
      "id": "6",
      "name": "Cancelamento / SLA",
      "description": "Respeitar prazo de cancelamento (24h padrão)",
      "triggers": ["cancelamento", "24 horas", "sla"],
      "scenarios": [
        "cancelamento de DC-e dentro e após 24 horas"
      ],
      "alert": "⚠️ Prazo de 24h obrigatório; fora do prazo requer análise SEFAZ",
      "color": "#F44336"
    },
    "7": {
      "id": "7",
      "name": "Desativação / Não emissão",
