    "9": {
      "id": "9",
      "name": "Pesados / Caminhões",
      "description": "Linha operacional específica de pesados/caminhões",
      "triggers": ["pesados", "caminhões", "gateway"],
      "scenarios": [
        "ativação - emissão de DC-e Caminhões"
      ],
      "alert": "Aplicar validações específicas de pesados",
      "color": "#3F51B5"
    }
  },

  "classification_rules": {
    "rule_1_anchor_required": {
      "description": "Âncora é obrigatória; sem ela, filtro fora",
      "pseudo_code": "IF NOT contains(anchor) THEN return false"
    },
    "rule_2_intention_precedence": {
      "description": "Intenção tem precedência sobre Contexto",
      "pseudo_code": "IF intention found THEN category = intention.primary_category ELSE category = context.primary_category"
    },
    "rule_3_context_then_complement": {
      "description": "Se múltiplos contextos, usar primeiro encontrado com weight maior",
      "pseudo_code": "IF multiple_contexts THEN sort by weight DESC; category = first.primary_category"
    },
    "rule_4_complement_enrich": {
      "description": "Complementos não criam categoria, apenas enriquecem com flags",
      "pseudo_code": "IF complement found THEN flags.push(complement.key)"
    },
    "rule_5_tie_breaker": {
      "description": "Em empate de Intenção (ex.: cancelado + reemissão), usar ordem de aparição no texto",
      "pseudo_code": "IF multiple_intentions THEN category = first_found_in_text.primary_category"
    }
  },

  "examples": [
    {
      "input": "DC-e cancelada com novo destino",
      "expected_category": "Reemissão / Cancelada / Novo destino",
      "expected_flags": [],
      "logic_trace": "Anchor ✓ | Intention: 'cancelada' + 'reemissão' → precedence → Reemissão | Context: none | Complement: none"
    },
    {
      "input": "gerar DC-e para cada CNPJ utilizado pelos PDI's",
      "expected_category": "CNPJ / PDI / Cadastro",
      "expected_flags": [],
      "logic_trace": "Anchor ✓ | Intention: 'gerar'→Emissão | Context: 'CNPJ'+'PDI' → tie between Emissão vs CNPJ; precedence: Intention wins → Emissão / Ativação"
    },
    {
      "input": "ativação VE leves",
      "expected_category": "VE Leves / LVE",
      "expected_flags": [],
      "logic_trace": "Anchor ✓ | Intention: 'ativação' → Emissão | Context: 'leves' → VE Leves; precedence: Intention > Context → Emissão / Ativação (mas VE Leves wins porque contexto é mais específico)"
    },
    {
      "input": "DC-e em contingência offline",
      "expected_category": "Emissão / Ativação",
      "expected_flags": ["contingencia"],
      "logic_trace": "Anchor ✓ | Intention: none | Context: none | Complement: 'contingência' → flags.push('contingencia'); sem Intention/Context → categoria é padrão"
    },
    {
      "input": "cancelamento de DC-e dentro de 24 horas",
      "expected_category": "Cancelamento / SLA",
      "expected_flags": ["sla_24h"],
      "logic_trace": "Anchor ✓ | Intention: 'cancelamento' → Cancelamento/SLA | Context: none | Complement: '24 horas' → flags.push('sla_24h')"
    },
    {
      "input": "DC-e TraaS Frete RAC realocação seminovos",
      "expected_category": "TraaS / Frete / Realocação",
      "expected_flags": [],
      "logic_trace": "Anchor ✓ | Intention: none | Context: 'traas'+'frete'+'realocação'+'sn' → TraaS (weight 2); outros também weight 2 → first found"
    }
  ]
}
