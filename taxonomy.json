{
  "metadata": {
    "version": "1.0",
    "date_created": "2026-03-26",
    "description": "Taxonomia operacional de triagem DC-e — Estrutura de palavras-chave por camadas (âncora, intenção, contexto, complemento) e mapeamento para categorias principais.",
    "precedence_rule": "Intenção > Contexto > Complemento",
    "notes": "Sem JS obrigatório; estrutura otimizada para parsing em HTML/CSS"
  },

  "layer_1_anchor": {
    "name": "Identificar Universo DC-e",
    "required": true,
    "variations": [
      "dce",
      "dc-e",
      "dc e",
      "declaração de conteúdo",
      "declaração de conteúdo eletrônica"
    ],
    "logic": "IF contém qualquer variação THEN domínio = DC-e ✓, caso contrário filtra fora"
  },

  "layer_2_intention": {
    "name": "Identificar Intenção (O que está acontecendo)",
    "keywords": {
      "ativacao": {
        "variations": ["ativação", "ativar", "ativando"],
        "primary_category": "Emissão / Ativação",
        "weight": 3
      },
      "emissao": {
        "variations": ["emissão", "emitir", "emitindo", "gerar", "gerar uma dce"],
        "primary_category": "Emissão / Ativação",
        "weight": 3
      },
      "cancelamento": {
        "variations": ["cancelamento", "cancelada", "cancelado", "cancelar"],
        "primary_category": "Cancelamento / SLA",
        "weight": 2
      },
      "reemissao": {
        "variations": ["reemissão", "reemitir", "novo destino", "a partir de uma dce cancelada"],
        "primary_category": "Reemissão / Cancelada / Novo destino",
        "weight": 2
      },
      "desativacao": {
        "variations": ["desativação", "operação desativação", "desativar"],
        "primary_category": "Desativação / Não emissão",
        "weight": 2
      },
      "nao_emissao": {
        "variations": ["não emissão", "não gerar dc-e", "bloqueado"],
        "primary_category": "Desativação / Não emissão",
        "weight": 2
      }
    }
  },

  "layer_3_context": {
    "name": "Identificar Contexto (Onde/Como)",
    "categories": {
      "CNPJ_PDI": {
        "variations": ["cnpj", "pdi", "cd", "cadastro de cnpj", "fornecedor", "rac", "gf", "42", "44"],
        "primary_category": "CNPJ / PDI / Cadastro",
        "weight": 2
      },
      "VE_Leves": {
        "variations": ["lve", "leves", "ve leves", "locavia"],
        "primary_category": "VE Leves / LVE",
        "weight": 2
      },
      "Valor": {
        "variations": ["abaixo de R$ 100.000,00", "100.000", "100000", "100 mil", "pabaixo", "limite", "faixa de valor"],
        "primary_category": "Regra de Valor",
        "weight": 1
      },
      "TraaS_Frete": {
        "variations": ["traas", "frete", "realocação", "realocação frota", "realocação seminovos", "sn", "seminovos"],
        "primary_category": "TraaS / Frete / Realocação",
        "weight": 2
      },
      "Pesados": {
        "variations": ["pesados", "caminhões", "gateway", "ativação pesados"],
        "primary_category": "Pesados / Caminhões",
        "weight": 2
      }
    }
  },

  "layer_4_complement": {
