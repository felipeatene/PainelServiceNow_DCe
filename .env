# ╔════════════════════════════════════════════════════════════╗
# ║  Painel DC-e — Variáveis de Ambiente                      ║
# ╚════════════════════════════════════════════════════════════╝

# ─── ServiceNow ───────────────────────────────────────────────
# Credenciais para login via formulário (opcional)
# Se definidos, permite pre-autenticação automática
SN_USER=
SN_PASS=

# Base URL do ServiceNow
SERVICENOW_BASE=https://ibmlocaliza.service-now.com

# ─── SharePoint ────────────────────────────────────────────────
# Site URL do SharePoint
SHAREPOINT_SITE_BASE=https://localiza.sharepoint.com/sites/DCE

# OAuth2 (App Registration no Microsoft Entra ID)
# Preencha para autenticação app-only no SharePoint
SHAREPOINT_TENANT_ID=
SHAREPOINT_CLIENT_ID=
SHAREPOINT_CLIENT_SECRET=

# Authority e scope para token client_credentials
# Exemplo de authority:
# SHAREPOINT_AUTHORITY=https://login.microsoftonline.com/<tenant-id>
SHAREPOINT_AUTHORITY=

# Scope recomendado para SharePoint REST app-only:
# https://<tenant>.sharepoint.com/.default
# Exemplo:
# SHAREPOINT_SCOPE=https://localiza.sharepoint.com/.default
SHAREPOINT_SCOPE=

# ─── JWT / Segurança ───────────────────────────────────────────
# Chave secreta para assinar JWT tokens
# ⚠️  GERE UMA CHAVE FORTE EM PRODUÇÃO!
# Exemplo: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=your-super-secret-key-change-this-in-production

# Validade dos tokens (em segundos)
JWT_ACCESS_EXPIRY=3600
JWT_REFRESH_EXPIRY=604800

# Origens permitidas para CORS (separadas por vírgula)
ALLOWED_ORIGINS=http://localhost:8080,http://127.0.0.1:8080

# Limites de autenticação por IP
RATE_LIMIT_ATTEMPTS=8
RATE_LIMIT_WINDOW_SECONDS=60

# Banco local para persistência de refresh tokens e auditoria
DB_PATH=auth.db

# ─── Servidor ──────────────────────────────────────────────────
PORT=8080
HOST=0.0.0.0

# ─── SSO / Azure AD (futuro) ──────────────────────────────────
# Configure para habilitar login Microsoft SSO
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_REDIRECT_URI=http://localhost:8080/auth/microsoft/callback
AZURE_SCOPE=openid profile email User.Read
